{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "vdf-spotify"
		},
		"AzureDataLakelinkedservice_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakelinkedservice'"
		},
		"azuresqllinkedservice_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azuresqllinkedservice'"
		},
		"AzureDataLakelinkedservice_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://vspotifyprojectstorage.dfs.core.windows.net/"
		},
		"azuresqllinkedservice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "vspotifyserver.database.windows.net"
		},
		"azuresqllinkedservice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "vspotifydatabase"
		},
		"azuresqllinkedservice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "vspotifyserver"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "vdf-spotify_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakelinkedservice_accountKey": {
						"value": "[parameters('AzureDataLakelinkedservice_accountKey')]"
					},
					"azuresqllinkedservice_password": {
						"value": "[parameters('azuresqllinkedservice_password')]"
					},
					"AzureDataLakelinkedservice_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakelinkedservice_properties_typeProperties_url')]"
					},
					"azuresqllinkedservice_properties_typeProperties_server": {
						"value": "[parameters('azuresqllinkedservice_properties_typeProperties_server')]"
					},
					"azuresqllinkedservice_properties_typeProperties_database": {
						"value": "[parameters('azuresqllinkedservice_properties_typeProperties_database')]"
					},
					"azuresqllinkedservice_properties_typeProperties_userName": {
						"value": "[parameters('azuresqllinkedservice_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}